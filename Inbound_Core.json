    {
      "parameters": {
        "jsCode": "const data = $('Code in JavaScript1').first().json;\nconst docId = $('Create a document').first().json.id;\n\n// 1. Витягуємо значення з нової структури\nconst volume        = parseFloat(data.calculation_input?.input_value_1) || 0;\nconst base_price    = parseFloat(data.pricing?.base_price) || 0;\nconst min_threshold = parseFloat(data.pricing?.min_threshold) || 0;\nconst discount_rate = parseFloat(data.pricing?.discount_rate) || 0;\nconst fixed_fee     = parseFloat(data.pricing?.fixed_fee) || 0;\n\n// 2. Логіка розрахунку\nconst raw_total = volume * base_price;\nconst discount_amount = (volume >= min_threshold && min_threshold > 0)\n  ? raw_total * discount_rate\n  : 0.0;\nconst final_sum = (raw_total - discount_amount) + fixed_fee;\n\n// 3. Статус виконання\nlet processing_log = \"OK\";\nif (base_price === 0) processing_log = \"WARNING: base_price is 0\";\nif (volume === 0)     processing_log = \"WARNING: volume is 0\";\n\n// 4. Повертаємо результат\nreturn {\n  json: {\n    // Контактні дані\n    full_name:        data.contact?.full_name || \"Невідомий клієнт\",\n    client_email:     data.contact?.email || \"\",\n    phone_number:     data.contact?.phone_number || \"\",\n\n    // Дані послуги\n    service_name:     data.pricing?.service_name || \"\",\n    category_id:      data.pricing?.category_id || \"\",\n    currency:         data.pricing?.currency || \"EUR\",\n\n    // Розрахунок\n    volume:           volume,\n    base_price:       base_price,\n    discount_applied: round(discount_amount, 2),\n    final_sum:        round(final_sum, 2),\n\n    // Поля для Аркуш3\n    calculated_result: round(final_sum, 2),\n    created_at:        new Date().toISOString(),\n    processing_log:    processing_log,\n\n    //ID текстового документа\n    doc_id: docId,\n  }\n};\n\nfunction round(val, decimals) {\n  return Math.round(val * 10**decimals) / 10**decimals;\n}"
      },
