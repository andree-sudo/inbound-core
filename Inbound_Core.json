        "jsCode": "const parts = $input.item.json.content.parts;\nconst lastPart = parts[parts.length - 1].text;\nconst clean = lastPart.replace(/```json|```/g, '').trim();\n\n// Якщо лист нерелевантний — передаємо далі без парсингу\nif (clean === \"Is Not Relevant\") {\n  return { json: { relevant: false, message: \"Is Not Relevant\" } };\n}\n\nconst parsed = JSON.parse(clean);\nreturn { json: { relevant: true, ...parsed } };"
      },
